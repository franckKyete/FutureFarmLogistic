# =============================================================================
# FUTURE FARM LOGISTIC — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.
# =============================================================================

# --- App ---
NODE_ENV=development
# PORT for the NestJS API (default: 3000)
API_PORT=3000

# --- Database (PostgreSQL) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=futurefarm
POSTGRES_USER=futurefarm
POSTGRES_PASSWORD=changeme

# Full connection URL (used by TypeORM)
DATABASE_URL=postgresql://futurefarm:changeme@localhost:5432/futurefarm

# --- JWT ---
# Generate with: openssl rand -hex 64
JWT_SECRET=changeme_replace_with_a_strong_random_secret
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3001

# --- Web (Vite) ---
VITE_API_BASE_URL=http://localhost:3000/v1

# --- Notifications ---
REDIS_URL=redis://localhost:6379

# Email (SMTP + Handlebars)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=secret
SMTP_FROM="FutureFarm <noreply@futurefarm.io>"

# Twilio (SMS + WhatsApp)
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Web Push
VAPID_PUBLIC_KEY=xxxx
VAPID_PRIVATE_KEY=xxxx
VAPID_SUBJECT=mailto:admin@futurefarm.io

# Feature Flags
WHATSAPP_ENABLED=false
PUSH_ENABLED=false

