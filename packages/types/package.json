{
  "name": "@futurefarm/types",
  "version": "0.0.1",
  "private": true,
  "description": "Shared TypeScript types and interfaces for the futurefarm platform",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./dist/index.js",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@futurefarm/config": "workspace:*",
    "typescript": "^5.8.3"
  }
}
